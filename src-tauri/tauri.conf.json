{
  "productName": "Wikiki",
  "version": "0.1.3",
  "identifier": "com.wikiki.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:8001",
    "beforeBuildCommand": "npm run build:vercel",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Wikiki",
        "width": 1000,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "label": "main"
      }
    ],
    "security": {
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Wikiki Contributors",
    "macOS": {
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256"
    }
  }
}
